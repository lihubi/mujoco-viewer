{
  "name": "@likang233/mujoco-viewer",
  "version": "0.1.0",
  "description": "Framework-agnostic TypeScript MuJoCo/MJCF viewer for browsers.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./assets/mujoco.wasm": "./dist/assets/mujoco.wasm"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "docs",
    "examples/assets",
    "examples/vanilla-vite/index.html",
    "examples/vanilla-vite/package.json",
    "examples/vanilla-vite/src",
    "examples/vanilla-vite/tsconfig.json",
    "examples/vanilla-vite/vite.config.ts",
    "examples/react-vite/index.html",
    "examples/react-vite/package.json",
    "examples/react-vite/src",
    "examples/react-vite/tsconfig.json",
    "examples/react-vite/vite.config.ts"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lihubi/mujoco-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/lihubi/mujoco-viewer/issues"
  },
  "homepage": "https://github.com/lihubi/mujoco-viewer#readme",
  "keywords": [
    "mujoco",
    "mjcf",
    "three",
    "threejs",
    "robotics",
    "viewer",
    "webgl",
    "typescript"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --target es2020 --clean --external three --external @mujoco/mujoco && node scripts/copy-wasm.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "pack:dry": "npm pack --dry-run",
    "examples:install": "npm --prefix examples/vanilla-vite install && npm --prefix examples/react-vite install",
    "examples:build": "npm --prefix examples/vanilla-vite run build && npm --prefix examples/react-vite run build",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build && npm run examples:install && npm run examples:build && npm pack --dry-run"
  },
  "dependencies": {
    "@mujoco/mujoco": "^3.9.0",
    "three": "^0.183.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.29",
    "@types/three": "^0.183.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  },
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20"
  }
}
